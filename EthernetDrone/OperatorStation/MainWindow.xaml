<Window x:Class="OperatorStation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mell DroneLab — Operator Station" Height="900" Width="1360"
        MinHeight="760" MinWidth="1180"
        WindowStartupLocation="CenterScreen">
    <TabControl Margin="12">
        <TabItem Header="CONTROL">
            <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="88"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="54"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="MELL DRONELAB" FontSize="25" FontWeight="Bold"/>
                    <TextBlock Text="Operator Station / VPS Relay" Foreground="{StaticResource Muted}" FontSize="13"/>
                </StackPanel>

                <UniformGrid Grid.Column="1" Columns="4" Margin="18,0">
                    <StackPanel Margin="8,0">
                        <TextBlock Text="VPS IP / HOST" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="VpsHostBox" Text="195.133.24.163"/>
                    </StackPanel>
                    <StackPanel Margin="8,0">
                        <TextBlock Text="PORT" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="VpsPortBox" Text="50555"/>
                    </StackPanel>
                    <StackPanel Margin="8,0">
                        <TextBlock Text="ROOM" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="RoomBox" Text="mell-drone"/>
                    </StackPanel>
                    <StackPanel Margin="8,0">
                        <TextBlock Text="SEND RATE" Style="{StaticResource LabelText}"/>
                        <TextBlock x:Name="RateText" Text="20 Hz / UDP" FontSize="19" FontWeight="SemiBold" Foreground="{StaticResource Warning}"/>
                    </StackPanel>
                </UniformGrid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="{StaticResource Panel2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="10,7" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="LinkLamp" Width="14" Height="14" Fill="#566070" Stroke="#AAB7CF" VerticalAlignment="Center"/>
                            <TextBlock x:Name="StatusText" Text="OFFLINE" FontSize="15" FontWeight="Bold" Margin="9,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="StartButton" Content="CONNECT" Width="110" Click="Start_Click"/>
                    <Button x:Name="StopButton" Content="STOP" Width="82" Click="Stop_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="390"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="INPUT DEVICE" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Выбирай DI: для полного набора стиков, осей и тумблеров" Foreground="{StaticResource Muted}" Margin="0,2,0,10" TextWrapping="Wrap"/>
                        <DockPanel>
                            <Button Content="⟳" Width="42" Click="RefreshJoysticks_Click" DockPanel.Dock="Right" Margin="6,0,0,0"/>
                            <ComboBox x:Name="JoystickCombo" DisplayMemberPath="Name" Height="34"/>
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,14,0,0">
                        <TextBlock Text="CALIBRATION" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Двигай стики по максимуму, потом отпусти в центр и нажми Finish." TextWrapping="Wrap" Foreground="{StaticResource Muted}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="CalStartButton" Content="START CAL" Click="CalStart_Click"/>
                            <Button x:Name="CalFinishButton" Content="FINISH" Click="CalFinish_Click" IsEnabled="False"/>
                            <Button Content="RESET" Click="CalReset_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <DataGrid Grid.Row="2" x:Name="AxesGrid" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,14,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Axis" Binding="{Binding AxisName}" IsReadOnly="True" Width="52"/>
                            <DataGridTextColumn Header="Raw" Binding="{Binding Raw}" IsReadOnly="True" Width="62"/>
                            <DataGridTextColumn Header="Min" Binding="{Binding Min}" Width="58"/>
                            <DataGridTextColumn Header="Center" Binding="{Binding Center}" Width="64"/>
                            <DataGridTextColumn Header="Max" Binding="{Binding Max}" Width="58"/>
                            <DataGridCheckBoxColumn Header="Inv" Binding="{Binding Invert}" Width="42"/>
                            <DataGridTextColumn Header="PWM" Binding="{Binding Pwm}" IsReadOnly="True" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <UniformGrid Grid.Row="3" Columns="2" Margin="0,14,0,0">
                        <StackPanel Margin="0,0,8,8"><TextBlock Text="Roll" Style="{StaticResource LabelText}"/><ComboBox x:Name="RollAxisCombo"/></StackPanel>
                        <StackPanel Margin="0,0,0,8"><TextBlock Text="Pitch" Style="{StaticResource LabelText}"/><ComboBox x:Name="PitchAxisCombo"/></StackPanel>
                        <StackPanel Margin="0,0,8,0"><TextBlock Text="Throttle" Style="{StaticResource LabelText}"/><ComboBox x:Name="ThrottleAxisCombo"/></StackPanel>
                        <StackPanel><TextBlock Text="Yaw" Style="{StaticResource LabelText}"/><ComboBox x:Name="YawAxisCombo"/></StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="310"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="LIVE CONTROL" Style="{StaticResource SectionTitle}"/>
                        <Border DockPanel.Dock="Right" Background="{StaticResource Panel2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6" Padding="8,3">
                            <TextBlock x:Name="SeqText" Text="SEQ 0" Foreground="{StaticResource Accent}" FontWeight="Bold"/>
                        </Border>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Margin="8" Background="{StaticResource Panel2}" CornerRadius="8" BorderBrush="{StaticResource Line}" BorderThickness="1">
                            <Grid>
                                <TextBlock Text="YAW / THROTTLE" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0" Style="{StaticResource LabelText}"/>
                                <Canvas x:Name="LeftStickCanvas" Width="260" Height="260" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Ellipse Width="250" Height="250" Stroke="#3A4650" StrokeThickness="2" Canvas.Left="5" Canvas.Top="5"/>
                                    <Ellipse Width="118" Height="118" Stroke="#29343D" StrokeThickness="1" Canvas.Left="71" Canvas.Top="71"/>
                                    <Line X1="10" Y1="130" X2="250" Y2="130" Stroke="#29343D" StrokeThickness="2"/>
                                    <Line X1="130" Y1="10" X2="130" Y2="250" Stroke="#29343D" StrokeThickness="2"/>
                                    <Ellipse x:Name="LeftStickDot" Width="22" Height="22" Fill="{StaticResource Accent2}"/>
                                </Canvas>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Margin="8" Background="{StaticResource Panel2}" CornerRadius="8" BorderBrush="{StaticResource Line}" BorderThickness="1">
                            <Grid>
                                <TextBlock Text="ROLL / PITCH" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0" Style="{StaticResource LabelText}"/>
                                <Canvas x:Name="RightStickCanvas" Width="260" Height="260" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Ellipse Width="250" Height="250" Stroke="#3A4650" StrokeThickness="2" Canvas.Left="5" Canvas.Top="5"/>
                                    <Ellipse Width="118" Height="118" Stroke="#29343D" StrokeThickness="1" Canvas.Left="71" Canvas.Top="71"/>
                                    <Line X1="10" Y1="130" X2="250" Y2="130" Stroke="#29343D" StrokeThickness="2"/>
                                    <Line X1="130" Y1="10" X2="130" Y2="250" Stroke="#29343D" StrokeThickness="2"/>
                                    <Ellipse x:Name="RightStickDot" Width="22" Height="22" Fill="{StaticResource Accent}"/>
                                </Canvas>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <Border x:Name="ArmPanel" Background="#3A1620" CornerRadius="8" Padding="10" Margin="0,6">
                                <StackPanel>
                                    <TextBlock Text="ARM" Style="{StaticResource LabelText}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="ArmText" Text="OFF" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{StaticResource Panel2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,6">
                                <StackPanel>
                                    <TextBlock Text="MODE" Style="{StaticResource LabelText}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="ModeText" Text="MANUAL" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{StaticResource Panel2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,6">
                                <StackPanel>
                                    <TextBlock Text="PING" Style="{StaticResource LabelText}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="PingText" Text="-- ms" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <DataGrid Grid.Row="2" x:Name="ChannelsGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CH" Binding="{Binding Name}" Width="70"/>
                            <DataGridTextColumn Header="PWM" Binding="{Binding Pwm}" Width="70"/>
                            <DataGridTemplateColumn Header="Level" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ProgressBar Minimum="1000" Maximum="2000" Value="{Binding Pwm}" Height="16"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="220"/>
                        <RowDefinition Height="72"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="SWITCH MAPPING" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Назначь кнопки, POV или Axis HIGH/LOW на действия" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="ButtonsGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Margin="0,12,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Button" Binding="{Binding Button}" Width="92"/>
                            <DataGridCheckBoxColumn Header="Pressed" Binding="{Binding Pressed}" Width="92"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="{StaticResource Panel2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="POV / HAT" Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="PovText" Text="CENTER" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="CAPTURE" Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="CaptureStatusText" Text="OFF" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Accent2}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="82"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="86"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ARM" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ArmButtonCombo" Margin="0,4"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="Захват" Click="CaptureArm_Click"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="LOITER" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="LoiterButtonCombo" Margin="0,4"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="Захват" Click="CaptureLoiter_Click"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="RTL" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="RtlButtonCombo" Margin="0,4"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="Захват" Click="CaptureRtl_Click"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="LAND" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="LandButtonCombo" Margin="0,4"/>
                        <Button Grid.Row="3" Grid.Column="2" Content="Захват" Click="CaptureLand_Click"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="MANUAL" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="ManualButtonCombo" Margin="0,4"/>
                        <Button Grid.Row="4" Grid.Column="2" Content="Захват" Click="CaptureManual_Click"/>
                    </Grid>

                    <StackPanel Grid.Row="4" VerticalAlignment="Bottom">
                        <UniformGrid Columns="2">
                            <Button Content="SAVE CONFIG" Click="SaveSettings_Click" Height="38"/>
                            <Button Content="LOAD CONFIG" Click="LoadSettings_Click" Height="38"/>
                        </UniformGrid>
                        <Border Background="{StaticResource Panel3}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="3,12,3,0">
                            <TextBlock Text="Failsafe: при потере пакетов Raspberry Pi должна сама отправлять нейтраль/RTL в ArduPilot." Foreground="{StaticResource Muted}" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="12">
            <DockPanel>
                <TextBlock x:Name="LastPacketText" Text="Packet: —" Foreground="{StaticResource Muted}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="VPS mode: Operator sends to relay, drone receives from relay" DockPanel.Dock="Right" Foreground="{StaticResource Accent}"/>
            </DockPanel>
        </Border>
            </Grid>
        </TabItem>

        <TabItem Header="OSD EDITOR">
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="620"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="OSD ELEMENTS" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="30 × 16 character grid, Betaflight / INAV style" Foreground="{StaticResource Muted}" Margin="0,2,0,0"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  x:Name="OsdElementsGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CurrentCellChanged="OsdElementsGrid_CurrentCellChanged">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" Width="48"/>
                                <DataGridTextColumn Header="Id" Binding="{Binding Id, UpdateSourceTrigger=PropertyChanged}" Width="82"/>
                                <DataGridTextColumn Header="Template" Binding="{Binding Template, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                <DataGridTextColumn Header="Row" Binding="{Binding Row, UpdateSourceTrigger=PropertyChanged}" Width="54"/>
                                <DataGridTextColumn Header="Col" Binding="{Binding Col, UpdateSourceTrigger=PropertyChanged}" Width="54"/>
                                <DataGridTemplateColumn Header="" Width="72">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Delete"
                                                    Padding="7,3"
                                                    MinHeight="24"
                                                    CommandParameter="{Binding}"
                                                    Click="DeleteOsdElement_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <UniformGrid Grid.Row="0" Columns="3">
                                <Button Content="ADD ELEMENT" Click="AddOsdElement_Click" Height="36"/>
                                <Button Content="RESET DEFAULT" Click="ResetDefaultOsd_Click" Height="36"/>
                                <Button Content="SAVE LOCAL" Click="SaveLocalOsd_Click" Height="36"/>
                            </UniformGrid>
                            <UniformGrid Grid.Row="1" Columns="3" Margin="0,6,0,0">
                                <Button Content="LOAD LOCAL" Click="LoadLocalOsd_Click" Height="36"/>
                                <Button Content="SEND TO DRONE" Click="SendOsdLayout_Click" Height="36"/>
                                <Button Content="SEND TEST VALUES" Click="SendOsdTestValues_Click" Height="36"/>
                            </UniformGrid>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="12,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="PREVIEW GRID" Style="{StaticResource SectionTitle}"/>
                            <TextBlock x:Name="OsdStatusText"
                                       Text="Local preview with test values"
                                       DockPanel.Dock="Right"
                                       Foreground="{StaticResource Accent}"
                                       FontWeight="SemiBold"/>
                        </DockPanel>

                        <Border Grid.Row="1" Background="{StaticResource Panel3}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="10">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <Canvas x:Name="OsdPreviewCanvas"
                                        Width="900"
                                        Height="480"
                                        Background="#090D11"
                                        MouseLeftButtonDown="OsdPreviewCanvas_MouseLeftButtonDown"
                                        MouseMove="OsdPreviewCanvas_MouseMove"
                                        MouseLeftButtonUp="OsdPreviewCanvas_MouseLeftButtonUp"/>
                            </ScrollViewer>
                        </Border>

                        <TextBlock Grid.Row="2"
                                   Text="Drag enabled elements on the grid. Templates use values like {mode}, {alt}, {bat}, {gps}, {link}, {ping}."
                                   Foreground="{StaticResource Muted}"
                                   TextWrapping="Wrap"
                                   Margin="2,10,2,0"/>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
